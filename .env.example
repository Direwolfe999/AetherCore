# ==============================================================================
# AetherCore Environment Variables Example
# Duplicate this file, rename it to .env.local, and fill in the values below.
# ==============================================================================

# A long, secret value used to encrypt the session cookie. 
# You can generate one using: `openssl rand -hex 32`
AUTH0_SECRET='your_generated_32_character_secret_here'

# The base URL of your application.
# Local: http://localhost:3000 
# Production: https://your-vercel-domain.vercel.app
AUTH0_BASE_URL='http://localhost:3000'

# Your Auth0 application settings
# Found in your Auth0 Dashboard -> Applications -> AetherCore -> Settings
AUTH0_ISSUER_BASE_URL='https://your-tenant-name.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'
