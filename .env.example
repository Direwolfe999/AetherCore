# ==============================================================================
# AetherCore Environment Variables Example
# Duplicate this file, rename it to .env.local, and fill in the values below.
# ==============================================================================

# A long, secret value used to encrypt the session cookie.
# Generate one with: openssl rand -hex 32
AUTH0_SECRET='your_generated_secret_here'

# Frontend application URL.
# Local dev example: http://localhost:3000
# Production example: https://aethercore-ai.vercel.app
AUTH0_BASE_URL='http://localhost:3000'

# Optional alias consumed by src/lib/auth0.ts for clarity.
APP_BASE_URL='http://localhost:3000'

# Backend target used by the Next.js backend proxy route.
# Set this to your Render backend URL in production.
# Local fallback remains http://localhost:8000 if unset.
BACKEND_URL='https://your-backend.onrender.com'

# Optional compatibility aliases. BACKEND_URL takes precedence.
RENDER_BACKEND_URL='https://your-backend.onrender.com'
NEXT_PUBLIC_API_URL='https://your-backend.onrender.com'

# Auth0 tenant and application settings from the dashboard.
AUTH0_ISSUER_BASE_URL='https://your-tenant.us.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'
