# ==============================================================================
# AetherCore Environment Variables Example
# Duplicate this file, rename it to .env.local, and fill in the values below.
# ==============================================================================

# A long, secret value used to encrypt the session cookie.
# Generate one with: openssl rand -hex 32
AUTH0_SECRET='your_generated_secret_here'

# The base URL of the app.
AUTH0_BASE_URL='http://localhost:3000'

# Auth0 tenant and application settings from the dashboard.
AUTH0_ISSUER_BASE_URL='https://your-tenant.us.auth0.com'
AUTH0_CLIENT_ID='your_auth0_client_id'
AUTH0_CLIENT_SECRET='your_auth0_client_secret'
